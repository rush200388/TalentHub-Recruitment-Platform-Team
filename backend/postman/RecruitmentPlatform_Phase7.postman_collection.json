                  "key": "token",
                  "value": "{{recruiterToken}}",
                  "type": "string"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jobApplicationId\": \"{{applicationId}}\",\n  \"interviewerUserId\": \"{{managerUserId}}\",\n  \"startTimeUtc\": \"{{interviewStart}}\",\n  \"endTimeUtc\": \"{{interviewEnd}}\",\n  \"type\": \"Online\",\n  \"meetingLink\": \"https://meet.example.com/interview\",\n  \"location\": null,\n  \"notes\": \"Technical and behavioural interview\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const start = new Date(Date.now() + 48 * 60 * 60 * 1000);",
                  "const end = new Date(start.getTime() + 60 * 60 * 1000);",
                  "pm.collectionVariables.set(\"interviewStart\", start.toISOString());",
                  "pm.collectionVariables.set(\"interviewEnd\", end.toISOString());"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Interview scheduled or existing workflow conflict explained\", function () {",
                  "  pm.expect([201, 400, 409]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set(\"interviewId\", pm.response.json().id);",
                  "}"
                ]
              }
            }
          ]
        },
